@model IEnumerable<PMMS.Models.MediaItem>

@{
    ViewData["Title"] = "My Watchlist";
}

<div class="container mt-4">
    <h2>My Watchlist</h2>
    
    <a href="/Media/Create" class="btn btn-primary mb-3">Add New Show</a>

    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Title</th>
                <th>Type</th>
                <th>Status</th>
                <th>Rating</th>
            </tr>
        </thead>
        <tbody>
            @* The C# foreach loop generates a new table row for every item in your database! *@
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.title</td>
                    <td>@item.type</td>
                    <td>@item.Status</td>
                    <td>@(item.UserRating.HasValue ? $"{item.UserRating}/10" : "Unrated")</td>
                </tr>
            }
        </tbody>
    </table>
</div>